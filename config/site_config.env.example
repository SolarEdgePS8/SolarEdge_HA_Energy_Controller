# SolarEdge HA Energy Controller – portable Standortkonfiguration
# Nach config/site_config.env kopieren oder mit scripts/discover_entities.py erzeugen.
# Diese private Datei nicht veröffentlichen.
#
# WICHTIG:
# - SITE_CONFIG_CONFIRMED bleibt NO, bis alle Entities und Einheiten geprüft sind.
# - Der Controller-Master wird durch diese Datei nicht automatisch eingeschaltet.
# - LIVE_* erwartet Momentanleistung in W, niemals Tagesenergie in kWh.

SITE_CONFIG_CONFIRMED=NO

# -----------------------------------------------------------------------------
# Pflicht
# -----------------------------------------------------------------------------
# Typisches SolarEdge-Modbus-Multi-Muster:
# number.solaredge_i1_storage_charge_limit
# Muss eine schreibbare number.*-Entity in W sein.
CHARGE_LIMIT_ENTITY=number.example_storage_charge_limit

# Typisches SolarEdge-Modbus-Multi-Muster:
# sensor.solaredge_i1_b1_state_of_energy
# Einheit: %
BATTERY_SOC_ENTITY=sensor.example_battery_soc

# Manueller Fallback: tatsächlich nutzbare Gesamtkapazität der eigenen Anlage.
# Nicht den Beispielwert einer anderen Anlage übernehmen.
BATTERY_CAPACITY_KWH=14.0

# Alle drei Forecast-Sensoren liefern Energie in kWh.
PV_FORECAST_TODAY_REMAINING_ENTITY=sensor.example_pv_today_remaining
PV_FORECAST_TODAY_TOTAL_ENTITY=sensor.example_pv_today_total
PV_FORECAST_TOMORROW_ENTITY=sensor.example_pv_tomorrow

# Kommagetrennte Prioritätslisten; Werte werden NICHT addiert.
# Nur Momentanleistung in W. Sensoren in kW vorher auf W normieren.
LIVE_PV_POWER_ENTITIES=sensor.example_pv_power_w
LIVE_CONSUMPTION_POWER_ENTITIES=sensor.example_house_consumption_power_w

# -----------------------------------------------------------------------------
# Optionale SolarEdge-Ziele
# Leer lassen, wenn Entity fehlt oder eine andere Automation Writer bleiben soll.
# Typische SolarEdge-Modbus-Multi-Muster stehen in docs/03_ENTITY_MAPPING.md.
# -----------------------------------------------------------------------------
DISCHARGE_LIMIT_ENTITY=
COMMAND_MODE_ENTITY=
COMMAND_MODE_GRID_OPTION=
COMMAND_MODE_DEFAULT_OPTION=
STORAGE_CONTROL_MODE_ENTITY=
STORAGE_CONTROL_REMOTE_OPTION=
BACKUP_RESERVE_ENTITY=

# -----------------------------------------------------------------------------
# Optionale Datenquellen
# -----------------------------------------------------------------------------
# Dynamische Kapazität, häufig sensor.solaredge_i1_b1_maximum_energy in kWh.
BATTERY_CAPACITY_ENTITY=
PV_FORECAST_DAY_AFTER_TOMORROW_ENTITY=
# Normale Home-Assistant-Weather-Entity mit hourly weather.get_forecasts.
WEATHER_ENTITY=
# Tagesenergie in kWh.
PV_YIELD_TODAY_ENTITY=
CONSUMPTION_TODAY_ENTITY=
# Monoton steigender PV-Energiezähler in Wh/kWh/MWh.
PV_LIFETIME_ENTITY=
# Aktuelle Prognoseleistung in W.
FORECAST_NOW_ENTITY=

# -----------------------------------------------------------------------------
# Optional evcc/EVOpt
# Die Basis-URL enthält nicht /api und nicht /api/state.
# Erst nach erfolgreichem API- und Batterie-Matching auf YES setzen.
# -----------------------------------------------------------------------------
EVOPT_ENABLED=NO
EVOPT_BASE_URL=http://EVCC-HOST:7070
EVOPT_BATTERY_TITLE=SolarEdge Akku
EVOPT_BATTERY_NAME=
# Optionales Zusatzsignal aus einer evcc-HA-Integration; nicht der EVOpt-Plan.
EVOPT_BATTERY_MODE_ENTITY=

# -----------------------------------------------------------------------------
# Optionale neutrale Signale externer Automationen
# -----------------------------------------------------------------------------
EXTERNAL_EV_CHARGING_ENTITY=
EXTERNAL_DISCHARGE_LOCK_ENTITY=
EXTERNAL_PEAK_LOCK_ENTITY=
