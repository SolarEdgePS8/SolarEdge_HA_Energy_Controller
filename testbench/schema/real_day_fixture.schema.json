{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SolarEdgePS8/SolarEdge_HA_Energy_Controller/testbench/schema/real_day_fixture.schema.json",
  "title": "SolarEdge HA Energy Controller 24h Fixture",
  "description": "Public, anonymized 15-minute fixture used by the independent model and Home Assistant replay.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "source_date",
    "timezone",
    "cadence_minutes",
    "slots",
    "battery_capacity_kwh",
    "battery_efficiency",
    "initial_soc_pct",
    "final_soc_pct",
    "actual_pv_kwh",
    "actual_load_kwh",
    "actual_grid_import_kwh",
    "actual_grid_export_kwh",
    "actual_battery_charge_kwh",
    "actual_battery_discharge_kwh",
    "forecast_scale_observed",
    "forecast_total_kwh",
    "evopt_timeline_kind",
    "privacy",
    "columns",
    "rows"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_\\-]{2,127}$"},
    "source_date": {"type": "string", "format": "date"},
    "timezone": {"const": "Europe/Berlin"},
    "cadence_minutes": {"const": 15},
    "slots": {"const": 96},
    "battery_capacity_kwh": {"type": "number", "exclusiveMinimum": 0, "maximum": 200},
    "battery_efficiency": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
    "initial_soc_pct": {"type": "number", "minimum": 0, "maximum": 100},
    "final_soc_pct": {"type": "number", "minimum": 0, "maximum": 100},
    "actual_pv_kwh": {"type": "number", "minimum": 0, "maximum": 500},
    "actual_load_kwh": {"type": "number", "minimum": 0, "maximum": 500},
    "actual_grid_import_kwh": {"type": "number", "minimum": 0, "maximum": 500},
    "actual_grid_export_kwh": {"type": "number", "minimum": 0, "maximum": 500},
    "actual_battery_charge_kwh": {"type": "number", "minimum": 0, "maximum": 500},
    "actual_battery_discharge_kwh": {"type": "number", "minimum": 0, "maximum": 500},
    "forecast_scale_observed": {"type": "number", "exclusiveMinimum": 0, "maximum": 5},
    "forecast_total_kwh": {"type": "number", "minimum": 0, "maximum": 500},
    "evopt_timeline_kind": {"type": "string", "minLength": 10, "maxLength": 160},
    "source_kind": {"type": "string", "minLength": 10, "maxLength": 160},
    "privacy": {"type": "string", "minLength": 20, "maxLength": 500},
    "columns": {
      "type": "array",
      "const": [
        "slot",
        "time",
        "minute",
        "pv_w",
        "home_w",
        "grid_import_w",
        "grid_export_w",
        "battery_charge_w",
        "battery_discharge_w",
        "soc_pct",
        "pv_actual_cumulative_kwh",
        "pv_forecast_total_kwh",
        "pv_forecast_remaining_kwh",
        "pv_forecast_tomorrow_kwh",
        "evopt_action",
        "evopt_healthy",
        "energy_balance_residual_w"
      ]
    },
    "rows": {
      "type": "array",
      "minItems": 96,
      "maxItems": 96,
      "items": {
        "type": "array",
        "minItems": 17,
        "maxItems": 17,
        "prefixItems": [
          {"type": "integer", "minimum": 0, "maximum": 95},
          {"type": "string", "pattern": "^(?:[01][0-9]|2[0-3]):(?:00|15|30|45)$"},
          {"type": "integer", "minimum": 0, "maximum": 1425, "multipleOf": 15},
          {"type": "number", "minimum": 0, "maximum": 100000},
          {"type": "number", "minimum": 0, "maximum": 100000},
          {"type": "number", "minimum": 0, "maximum": 100000},
          {"type": "number", "minimum": 0, "maximum": 100000},
          {"type": "number", "minimum": 0, "maximum": 100000},
          {"type": "number", "minimum": 0, "maximum": 100000},
          {"type": "number", "minimum": 0, "maximum": 100},
          {"type": "number", "minimum": 0, "maximum": 500},
          {"type": "number", "minimum": 0, "maximum": 500},
          {"type": "number", "minimum": 0, "maximum": 500},
          {"type": "number", "minimum": 0, "maximum": 500},
          {"enum": ["normal", "holdcharge", "charge", "discharge", "hold", "unavailable"]},
          {"type": "boolean"},
          {"type": "number", "minimum": -20, "maximum": 20}
        ]
      }
    }
  }
}
